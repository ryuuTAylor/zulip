<div id="create-recurring-scheduled-message-modal">
    <form class="modal-form" id="create-recurring-scheduled-message-form">
        <div class="modal-field-label">{{t "Message content" }}</div>
        <textarea
            id="recurring-scheduled-message-content"
            class="modal-textarea"
            rows="4"
            placeholder="{{t 'Write your message here…' }}"
        ></textarea>

        <div class="modal-field-label">{{t "Recurrence" }}</div>
        <select id="recurring-scheduled-message-recurrence-type" class="modal-select">
            <option value="daily">{{t "Daily" }}</option>
            <option value="weekly">{{t "Weekly" }}</option>
            <option value="specific_days">{{t "Specific days" }}</option>
            <option value="one_time">{{t "One time" }}</option>
        </select>

        <div id="recurrence-days-section" class="modal-field-section">
            <div class="modal-field-label">{{t "Days of week" }}</div>
            <div class="recurrence-days-checkboxes">
                <label><input type="checkbox" class="recurrence-day-checkbox" value="0" /> {{t "Mon" }}</label>
                <label><input type="checkbox" class="recurrence-day-checkbox" value="1" /> {{t "Tue" }}</label>
                <label><input type="checkbox" class="recurrence-day-checkbox" value="2" /> {{t "Wed" }}</label>
                <label><input type="checkbox" class="recurrence-day-checkbox" value="3" /> {{t "Thu" }}</label>
                <label><input type="checkbox" class="recurrence-day-checkbox" value="4" /> {{t "Fri" }}</label>
                <label><input type="checkbox" class="recurrence-day-checkbox" value="5" /> {{t "Sat" }}</label>
                <label><input type="checkbox" class="recurrence-day-checkbox" value="6" /> {{t "Sun" }}</label>
            </div>
        </div>

        <div class="modal-field-label">{{t "Time (UTC)" }}</div>
        <input
            id="recurring-scheduled-message-time"
            type="time"
            class="modal_text_input"
            value="09:00"
        />

        <div id="one-time-timestamp-section" class="modal-field-section">
            <div class="modal-field-label">{{t "Send at" }}</div>
            <input
                id="recurring-scheduled-message-datetime"
                type="datetime-local"
                class="modal_text_input"
            />
        </div>

        <div class="modal-field-label">{{t "Destinations" }}</div>
        <div id="rsm-destinations-list"></div>

        <div id="rsm-add-stream-form" class="rsm-add-dest-form">
            <input
                id="rsm-stream-name-input"
                type="text"
                class="modal_text_input"
                placeholder="{{t 'Channel name' }}"
            />
            <input
                id="rsm-topic-input"
                type="text"
                class="modal_text_input"
                placeholder="{{t 'Topic' }}"
            />
            <button type="button" id="rsm-add-stream-btn" class="button small rounded">
                {{t "+ Add channel" }}
            </button>
        </div>

        <div id="rsm-add-direct-form" class="rsm-add-dest-form">
            <input
                id="rsm-dm-emails-input"
                type="text"
                class="modal_text_input"
                placeholder="{{t 'Emails, comma-separated' }}"
            />
            <button type="button" id="rsm-add-direct-btn" class="button small rounded">
                {{t "+ Add direct message" }}
            </button>
        </div>
    </form>
</div>
